FROM nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

# 设置非交互式安装和环境变量
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
# 告诉 CTranslate2 库去哪找 CUDA/cuDNN（可选，通常 nvidia 基础镜像已配好）
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH

# 1. 安装 Python 3.10、pip、FFmpeg 和用于权限控制的 gosu
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3.10 python3-pip python3.10-venv \
    ffmpeg gosu && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 2. 将 python 命令软连接到 python3.10，确保 pip 等脚本正常工作
RUN ln -sf /usr/bin/python3.10 /usr/bin/python && \
    ln -sf /usr/bin/python3.10 /usr/bin/python3

# [新增] 升级基础打包工具，防止由于老版本 pip 导致拉取 wheel 包失败
RUN python3 -m pip install --upgrade pip setuptools wheel

# 3. 设置工作目录
WORKDIR /app

# 4. 首先拷贝 requirements 以利用 Docker 构建缓存
COPY requirements.txt .

# 5. 安装 Python 依赖 
# [核心修改] 添加 --extra-index-url 直接拉取适配 CUDA 12.2 的预编译大模型依赖包，跳过本地 C++ 编译
RUN pip install --no-cache-dir -r requirements.txt \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu122

# 6. 拷贝整个项目代码到容器中
COPY . .

# [原逻辑] 备份默认配置文件到不受挂载影响的根目录，防止被用户的空 volume 覆盖
RUN cp config/config.example.json /app/config.example.json

# 7. 转换换行符为 Unix 格式并赋予 entrypoint 脚本执行权限
RUN sed -i 's/\r$//' docker-entrypoint.sh && chmod +x docker-entrypoint.sh

# 暴露 FastAPI 端口
EXPOSE 8000

# 8. 定义启动入口 (接管 PUID/PGID 的处理)
ENTRYPOINT ["/app/docker-entrypoint.sh"]

# 9. 默认启动命令
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]